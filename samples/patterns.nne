match literal {
  42   -> "integer"
  3.14 -> "float"
  "Hi" -> "string"
}


match wildcard {
  _ -> "anything"
}


match tuple {
  (1, 2) -> "tuples are the same as lists"
}


match list {
  []  -> "empty list"
  [1] -> "one item"
  [42, 3.14, "Hello"] -> "multiple items"
}


match nested {
  ["really", ["nested", ["patterns"]]] -> "really nested"
}


match bindings {
  [first, second, third] -> {
    print("1st: {first}")
    print("2nd: {second}")
    print("3rd: {third}")
  }
}